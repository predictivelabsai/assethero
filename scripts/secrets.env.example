# AssetHero Cloud Run secrets — copy to a private location, fill in, and load
# into Secret Manager (see scripts/deploy_gcp.sh). NEVER commit real values.
#
# Landing page needs NONE of these. Login + in-app features need them.

# PostgreSQL connection string (Cloud SQL or external), alpatrade schema.
DATABASE_URL=

# Fernet key for encrypting per-user Alpaca keys. Generate:
#   python scripts/generate_keys.py
ENCRYPTION_KEY=

# JWT signing secret (API auth). Generate with the same script.
JWT_SECRET=

# Google OAuth (optional — enables the "Continue with Google" button).
# Create an OAuth 2.0 Client (Web) in GCP → APIs & Services → Credentials,
# add <cloud-run-url>/auth/callback as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
